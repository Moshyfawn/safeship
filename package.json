{
  "name": "@moshyfawn/safeship",
  "version": "0.0.0",
  "description": "One-shot setup for secure npm package publishing: OIDC trusted publishing, staged publishing, hardened CI/CD.",
  "keywords": [
    "cli",
    "github-actions",
    "npm",
    "oidc",
    "provenance",
    "publish",
    "secure-publishing",
    "staged-publishing",
    "supply-chain",
    "trusted-publishing"
  ],
  "license": "MIT",
  "author": "moshyfawn <email@moshyfawn.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Moshyfawn/safeship.git"
  },
  "bin": {
    "safeship": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "dev": "tsdown --watch",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint src/",
    "version": "changeset version"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "publint": "^0.3.17",
    "tsdown": "latest",
    "typescript": "^5.7.0",
    "unplugin-unused": "^0.5.7"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
